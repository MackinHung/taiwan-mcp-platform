{
  "name": "formosa-mcp-platform",
  "private": true,
  "workspaces": [
    "packages/*",
    "servers/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:shared": "cd packages/shared && npm test",
    "test:gateway": "cd packages/gateway && npm test",
    "test:review": "cd packages/review && npm test",
    "test:composer": "cd packages/composer && npm test",
    "test:weather": "cd servers/taiwan-weather && npm test",
    "test:air-quality": "cd servers/taiwan-air-quality && npm test",
    "test:electricity": "cd servers/taiwan-electricity && npm test",
    "test:stock": "cd servers/taiwan-stock && npm test",
    "test:news": "cd servers/taiwan-news && npm test",
    "test:hospital": "cd servers/taiwan-hospital && npm test",
    "test:company": "cd servers/taiwan-company && npm test",
    "lint": "eslint packages/ servers/ --ext .ts",
    "clawhub:publish": "npx tsx scripts/clawhub-publish.ts",
    "clawhub:dry-run": "npx tsx scripts/clawhub-publish.ts --dry-run",
    "generate:cli": "node scripts/generate-cli.mjs",
    "generate:server-json": "node scripts/generate-server-json.mjs",
    "build:servers": "npm run build --workspaces --if-present",
    "publish:npm": "node scripts/npm-publish.mjs",
    "publish:npm:dry-run": "node scripts/npm-publish.mjs --dry-run",
    "publish:registry": "node scripts/registry-publish.mjs",
    "publish:registry:dry-run": "node scripts/registry-publish.mjs --dry-run",
    "publish:smithery": "node scripts/smithery-publish.mjs",
    "publish:smithery:dry-run": "node scripts/smithery-publish.mjs --dry-run",
    "publish:pulsemcp": "node scripts/pulsemcp-entry.mjs"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250312.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
