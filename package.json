{
  "name": "taiwan-mcp-platform",
  "private": true,
  "workspaces": [
    "packages/*",
    "servers/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:shared": "cd packages/shared && npm test",
    "test:gateway": "cd packages/gateway && npm test",
    "test:review": "cd packages/review && npm test",
    "test:composer": "cd packages/composer && npm test",
    "test:weather": "cd servers/taiwan-weather && npm test",
    "test:air-quality": "cd servers/taiwan-air-quality && npm test",
    "test:electricity": "cd servers/taiwan-electricity && npm test",
    "test:stock": "cd servers/taiwan-stock && npm test",
    "test:news": "cd servers/taiwan-news && npm test",
    "test:hospital": "cd servers/taiwan-hospital && npm test",
    "test:company": "cd servers/taiwan-company && npm test",
    "lint": "eslint packages/ servers/ --ext .ts",
    "clawhub:publish": "npx tsx scripts/clawhub-publish.ts",
    "clawhub:dry-run": "npx tsx scripts/clawhub-publish.ts --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@cloudflare/workers-types": "^4.20250312.0",
    "wrangler": "^4.0.0"
  }
}
